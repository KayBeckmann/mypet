# =====================================================
# MyPet - Umgebungsvariablen
# =====================================================
# Kopiere diese Datei nach .env und passe die Werte an:
# cp .env.example .env
# =====================================================

# ===== Datenbank =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mypet
POSTGRES_USER=mypet_user
POSTGRES_PASSWORD=change-me-in-production

# ===== Backend =====
BACKEND_PORT=8080

# API-URL für die Flutter-Web-Apps (wird beim Build übergeben)
# In Produktion: https://api.deinedomain.de
API_BASE_URL=http://localhost:8080

# JWT Konfiguration
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRY=3600

# Verschlüsselung (32 Zeichen für AES-256)
ENCRYPTION_KEY=change-me-to-a-32-character-key!

# ===== Datei-Upload =====
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10485760

# ===== Frontend Ports =====
OWNER_PORT=3001
VET_PORT=3002
PROVIDER_PORT=3003
ADMIN_PORT=3004

# ===== E-Mail (optional) =====
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=MyPet <noreply@example.com>

# ===== Superadmin (wird beim ersten Start automatisch angelegt) =====
SUPERADMIN_EMAIL=admin@mypet.local
SUPERADMIN_PASSWORD=change-me-in-production
SUPERADMIN_NAME=Super Admin

# ===== pgAdmin (Entwicklung) =====
PGADMIN_EMAIL=admin@mypet.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ===== Android App =====
# API-URL für die Android APK — Standard ist der Android-Emulator-Host (10.0.2.2)
# Für echte Geräte: öffentliche IP oder Domain des Backends eintragen
ANDROID_API_URL=http://10.0.2.2:8080

# ===== Entwicklung =====
# DEBUG=true
# LOG_LEVEL=debug
